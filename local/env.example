# ローカル実行用の通知設定。GitHub Secrets と同じ値を入れる。
# このファイルを リポジトリ直下の .env にコピーして値を埋める（.env はコミットされない）。
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-address@gmail.com
SMTP_PASSWORD=16文字のアプリパスワード（スペースなし）
RECIPIENT_EMAIL=your-address@gmail.com
# Discord Webhook（任意。設定すればDiscordにも通知）
WEBHOOK_URL=
# 楽天市場APIのアプリID（任意。設定すると楽天ブックス在庫監視が有効になる）
RAKUTEN_APP_ID=
# ntfy.sh のトピック名（任意。スマホのntfyアプリで同じtopicを購読するとプッシュ通知が届く。
# 推測されにくいランダムな文字列にすること 例: resale-a8k2xxxxxx）
NTFY_TOPIC=
